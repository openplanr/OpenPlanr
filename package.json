{
  "name": "openplanr",
  "version": "1.2.3",
  "description": "AI-powered planning CLI — backlog, sprints, task templates, estimation, GitHub sync, and AI agent rules for Cursor, Claude Code, and Codex",
  "type": "module",
  "main": "./dist/cli/index.js",
  "types": "./dist/cli/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/cli/index.js",
      "types": "./dist/cli/index.d.ts"
    }
  },
  "bin": {
    "planr": "./bin/planr.js",
    "opr": "./bin/planr.js"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "files": [
    "dist/",
    "bin/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && rm -rf dist/templates && cp -r src/templates dist/templates",
    "dev": "tsx src/cli/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check src/ tests/",
    "lint:fix": "biome check --write src/ tests/",
    "format": "biome format --write src/ tests/",
    "format:check": "biome format src/ tests/",
    "prepare": "husky",
    "prepublishOnly": "npm run build",
    "changeset": "changeset",
    "version-packages": "changeset version"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "agile",
    "planning",
    "cli",
    "cursor",
    "claude",
    "codex",
    "ai",
    "backlog",
    "sprint",
    "templates",
    "estimation",
    "github",
    "epic",
    "user-story",
    "scrum"
  ],
  "author": "OpenPlanr Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/openplanr/OpenPlanr.git"
  },
  "homepage": "https://openplanr.dev",
  "bugs": {
    "url": "https://github.com/openplanr/OpenPlanr/issues"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.81.0",
    "@inquirer/prompts": "^8.3.2",
    "@napi-rs/keyring": "^1.2.0",
    "chalk": "^5.3.0",
    "commander": "^14.0.3",
    "gray-matter": "^4.0.3",
    "handlebars": "^4.7.9",
    "openai": "^6.33.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@changesets/cli": "^2.30.0",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "tsx": "^4.19.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
