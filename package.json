{
  "name": "openplanr",
  "version": "0.5.0",
  "description": "CLI tool for agile planning with AI agents — generates epics, features, stories, tasks, and AI rule files for Cursor, Claude Code, and Codex",
  "type": "module",
  "main": "./dist/cli/index.js",
  "types": "./dist/cli/index.d.ts",
  "bin": {
    "planr": "./bin/planr.js",
    "opr": "./bin/planr.js"
  },
  "files": [
    "dist/",
    "bin/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && rm -rf dist/templates && cp -r src/templates dist/templates",
    "dev": "tsx src/cli/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "prepare": "husky",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "agile",
    "planning",
    "cli",
    "cursor",
    "claude",
    "codex",
    "ai",
    "epic",
    "user-story",
    "scrum"
  ],
  "author": "OpenPlanr Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TechArc-io/OpenPlanr.git"
  },
  "homepage": "https://github.com/TechArc-io/OpenPlanr#readme",
  "bugs": {
    "url": "https://github.com/TechArc-io/OpenPlanr/issues"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@inquirer/prompts": "^8.3.2",
    "@napi-rs/keyring": "^1.2.0",
    "chalk": "^5.3.0",
    "commander": "^14.0.3",
    "gray-matter": "^4.0.3",
    "handlebars": "^4.7.9",
    "openai": "^6.33.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "tsx": "^4.19.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.2"
  }
}
